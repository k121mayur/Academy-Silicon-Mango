# Database
DATABASE_URL=postgresql+asyncpg://sm_user:sm_secure_pass_2024@localhost:5432/silicon_mango

# Redis
REDIS_URL=redis://:sm_redis_pass_2024@localhost:6379/0

# JWT
SECRET_KEY=change-this-to-a-256-bit-random-string-in-production-please
ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256

# Google OAuth (optional - leave blank to disable)
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=
GOOGLE_REDIRECT_URI=http://localhost:8085/api/v1/auth/google/callback

# SMTP Email (optional - OTP will be logged to console if not set)
SMTP_HOST=
SMTP_PORT=587
SMTP_USER=
SMTP_PASSWORD=
FROM_EMAIL=Silicon Mango Academy <noreply@siliconmango.com>

# Razorpay (optional)
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# Storage
UPLOAD_DIR=./uploads

# Frontend URL (for CORS and OAuth redirects)
FRONTEND_URL=http://localhost:5174

# Master Admin (created on first startup)
MASTER_ADMIN_EMAIL=admin@siliconmango.com
MASTER_ADMIN_PASSWORD=Admin@12345

# Environment
ENVIRONMENT=development
