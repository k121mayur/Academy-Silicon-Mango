# ============================================================
#  Silicon Mango Academy — Backend Environment Variables
#  Used by: FastAPI application (app/core/config.py)
# ============================================================
#
#  Copy this file:  cp backend/.env.example backend/.env
#  Then fill in the values marked with  <-- CHANGE THIS
#
#  When running via docker-compose, DATABASE_URL and REDIS_URL
#  are injected automatically from docker-compose.yml — you only
#  need them here for local development (uvicorn outside Docker).
#
# ============================================================


# ── Database ────────────────────────────────────────────────────────────────
# Docker:  overridden automatically by docker-compose.yml (uses service name "postgres")
# Local:   points to localhost — match the password in root .env (DB_PASSWORD)

DATABASE_URL=postgresql+asyncpg://sm_user:Sm@SecurePass2024!@localhost:5432/silicon_mango


# ── Redis ───────────────────────────────────────────────────────────────────
# Docker:  overridden automatically by docker-compose.yml (uses service name "redis")
# Local:   points to localhost — match the password in root .env (REDIS_PASSWORD)

REDIS_URL=redis://:RedisSm@2024!@localhost:6379/0


# ── JWT / Auth ──────────────────────────────────────────────────────────────
# SECRET_KEY: generate a strong random key with:
#   python -c "import secrets; print(secrets.token_hex(64))"
# Never reuse the same key across environments.

SECRET_KEY=a3f8e2c1d4b7a9e6f2c8d1b4a7e3c9f6d2b8a1e7f4c2b9d5a8e1f6c3b0d7a4e2  # <-- CHANGE THIS

ACCESS_TOKEN_EXPIRE_MINUTES=15
REFRESH_TOKEN_EXPIRE_DAYS=7
ALGORITHM=HS256


# ── Google OAuth (optional) ─────────────────────────────────────────────────
# Leave blank to disable Google login — email/OTP login still works.
# Obtain credentials from: https://console.cloud.google.com/apis/credentials
# Authorised redirect URI to register:
#   http://localhost:8085/api/v1/auth/google/callback    (local dev)
#   https://yourdomain.com/api/v1/auth/google/callback   (production)

GOOGLE_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz012345.apps.googleusercontent.com
GOOGLE_CLIENT_SECRET=GOCSPX-AbCdEfGhIjKlMnOpQrStUvWx01234
GOOGLE_REDIRECT_URI=http://localhost:8085/api/v1/auth/google/callback


# ── SMTP Email (optional) ───────────────────────────────────────────────────
# Leave blank to disable email — OTP codes will be printed to the console log.
# Example below uses Gmail App Passwords.
# Gmail: enable 2FA → https://myaccount.google.com/apppasswords → generate password
#
# Other providers:
#   SendGrid:  host=smtp.sendgrid.net  port=587  user=apikey  password=<sendgrid_api_key>
#   Mailgun:   host=smtp.mailgun.org   port=587  user=<domain_user>

SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=your-email@gmail.com                # <-- CHANGE THIS
SMTP_PASSWORD=abcd efgh ijkl mnop             # <-- 16-char Gmail App Password
FROM_EMAIL=Silicon Mango Academy <noreply@yourdomain.com>


# ── Razorpay Payment Gateway ────────────────────────────────────────────────
# TWO independent key pairs. The admin "Payment Settings" page only toggles
# which pair is ACTIVE — these secrets stay on the server and are never shown
# in the UI or stored in the database.
#   TEST → rzp_test_* keys. Fake money, test cards/UPI. Safe to experiment with.
#   LIVE → rzp_live_* keys. Real money, settled to your bank by Razorpay.
# Get both from https://dashboard.razorpay.com → Settings → API Keys
# (flip the dashboard's Test/Live switch to generate each pair).
# Leave a pair blank to keep that mode disabled — the app refuses to switch to
# a mode whose keys aren't filled in here.

RAZORPAY_TEST_KEY_ID=rzp_test_AbCdEfGhIjKlMn
RAZORPAY_TEST_KEY_SECRET=superSecretTestKeyGoesHere123
RAZORPAY_LIVE_KEY_ID=
RAZORPAY_LIVE_KEY_SECRET=


# ── Cloudflare Turnstile CAPTCHA (optional) ─────────────────────────────────
# Protects the PUBLIC webinar registration form from bots. Leave BOTH blank to
# disable — the form still works and the backend simply skips CAPTCHA checks
# (email verification + rate limiting remain active).
# Get keys from: https://dash.cloudflare.com → Turnstile → Add site.
# The SECRET key is used here (server-side siteverify); the SITE key goes in the
# root .env as TURNSTILE_SITE_KEY (baked into the frontend at build time).

TURNSTILE_SITE_KEY=
TURNSTILE_SECRET_KEY=


# ── File Storage ─────────────────────────────────────────────────────────────
# Relative to the backend working directory.
# In Docker this maps to the host volume ./backend/uploads via docker-compose.yml.

UPLOAD_DIR=./uploads


# ── CORS / Frontend URL ───────────────────────────────────────────────────────
# The URL where the frontend is served.
# Used for CORS headers and OAuth callback redirects.
# Local dev (Vite):     http://localhost:3000
# Docker compose:       http://localhost:5174
# Production:           https://yourdomain.com

FRONTEND_URL=http://localhost:5174


# ── Master Admin Account ─────────────────────────────────────────────────────
# Created automatically on first startup if no admin exists.
# Change these before deploying to production!

MASTER_ADMIN_EMAIL=admin@yourdomain.com       # <-- CHANGE THIS
MASTER_ADMIN_PASSWORD=Admin@12345             # <-- CHANGE THIS (min 8 chars, 1 upper, 1 digit, 1 special)


# ── Video streaming & CDN ──────────────────────────────────────────────────────
# VIDEO_STREAM_SECRET: HMAC key for the per-user playlist gate. Generate with:
#   python -c "import secrets; print(secrets.token_hex(32))"
VIDEO_STREAM_SECRET=change_me_generate_a_64_char_hex_secret   # <-- CHANGE THIS
#
# SEGMENT_SIGNING_SECRET: shared secret for cacheable HLS segment URLs. MUST be
# identical to the value nginx uses (root .env SEGMENT_SIGNING_SECRET). When
# running via docker-compose it is injected from the root .env automatically.
SEGMENT_SIGNING_SECRET=change_me_generate_a_64_char_hex_secret
#
# Segment URL expiry is snapped to a fixed bucket so all concurrent viewers share
# one CDN-cacheable URL. Lower = tighter revocation, slightly less cache reuse.
SEGMENT_URL_TTL_SECONDS=900
SEGMENT_URL_BUCKET_SECONDS=900
#
# Local dev only: let FastAPI serve .ts segments itself (in production nginx does).
SERVE_SEGMENTS_FROM_APP=false
#
# Encoding resource caps (small-box safety)
FFMPEG_THREADS=1
ENCODE_TIMEOUT_SECONDS=1800


# ── Environment ───────────────────────────────────────────────────────────────
# Values: development | staging | production
# Setting "production" enables:
#   - Secure-only cookies (HTTPS required)
#   - Stricter CORS (only FRONTEND_URL allowed)
#   - /docs, /redoc, /openapi.json disabled

ENVIRONMENT=development
