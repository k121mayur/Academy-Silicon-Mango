# Keep the build context lean and never bake host-only artifacts into the image.
# The image installs its own deps via pip (requirements.txt) and creates its own
# uploads/media dirs; those are bind-mounted at runtime by docker-compose.
.venv/
venv/
env/
__pycache__/
*.py[cod]
*.egg-info/
.pytest_cache/
.mypy_cache/
.ruff_cache/
.coverage
htmlcov/

# Runtime data — mounted as volumes, must not be copied into the image.
uploads/
media/

# Local tooling / noise
.git/
.gitignore
*.log
.DS_Store
