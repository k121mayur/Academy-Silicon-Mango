# ============================================================
#  Silicon Mango Academy — Root Environment Variables
#  Used by: docker-compose.yml
# ============================================================
#
#  QUICK START (3 steps):
#    1. cp .env.example              .env
#    2. cp backend/.env.example      backend/.env
#    3. cp frontend/.env.example     frontend/.env
#  Then edit each file with real values and run:
#    docker compose up -d --build
#
# ============================================================


# ── PostgreSQL ──────────────────────────────────────────────────────────────
# Password for the 'sm_user' database account.
# Must match MASTER_ADMIN_PASSWORD and any backup scripts you run.
# Allowed chars: letters, digits, @, #, $, !, _ (avoid % and & in URLs)

DB_PASSWORD=Sm@SecurePass2024!


# ── Redis ───────────────────────────────────────────────────────────────────
# Password for the Redis instance used for OTP caching and rate-limiting.

REDIS_PASSWORD=RedisSm@2024!


# ── Video segment signing (CDN) ─────────────────────────────────────────────
# Shared HMAC secret used to sign cacheable HLS segment URLs. It is injected
# into BOTH the backend (issuer) and the frontend nginx (verifier), so they
# MUST be identical. Generate a strong random value, e.g.:
#     python -c "import secrets; print(secrets.token_hex(32))"

SEGMENT_SIGNING_SECRET=change_me_generate_a_64_char_hex_secret


# ── Cloudflare Turnstile site key (optional) ────────────────────────────────
# Public site key for the webinar registration CAPTCHA. Baked into the frontend
# at build time (docker-compose passes it as a build arg). Leave blank to disable
# the widget. The matching SECRET key goes in backend/.env (TURNSTILE_SECRET_KEY).

TURNSTILE_SITE_KEY=


# ── Public hostname ─────────────────────────────────────────────────────────
# The domain the app is served on (used by nginx server_name). In local dev
# leave as "_". In production set to e.g. academy.example.com.

SERVER_NAME=_


# ── Cloudflare origin lock-down (production only) ────────────────────────────
# A random secret echoed by a Cloudflare Transform Rule as the X-Origin-Auth
# header; the origin nginx rejects any request without it. Generate with:
#     python -c "import secrets; print(secrets.token_hex(24))"
# Only used by docker-compose.prod.yml / nginx.prod.conf.

ORIGIN_SHARED_SECRET=change_me_random_origin_header_secret


# ── Notes ───────────────────────────────────────────────────────────────────
# DATABASE_URL and REDIS_URL are automatically constructed from the values
# above by docker-compose.yml and injected into the backend container.
# You do NOT need to set them here.
#
# For local development (running the backend outside Docker), set them
# directly in backend/.env — see that file for details.
#
# PRODUCTION: generate fresh, strong values for DB_PASSWORD, REDIS_PASSWORD,
# SEGMENT_SIGNING_SECRET, and (in backend/.env) SECRET_KEY, VIDEO_STREAM_SECRET,
# MASTER_ADMIN_PASSWORD. Never reuse the example defaults. See DEPLOYMENT.md.
