# ============================================================
#  Silicon Mango Academy — Frontend Environment Variables
#  Used by: Vite build (values are baked in at build time)
# ============================================================
#
#  Copy this file:  cp frontend/.env.example frontend/.env
#
#  All variables MUST start with VITE_ to be exposed to the browser.
#  Changes require a rebuild:  npm run build  (or docker compose build frontend)
#
# ============================================================


# ── API Base URL ──────────────────────────────────────────────────────────────
# Where the frontend sends API requests.
# Leave blank to use the same origin (/api via Vite/nginx proxy).
# Local dev override:      http://localhost:8085
# Production API domain:   https://api.yourdomain.com

VITE_API_BASE_URL=


# ── Google OAuth Client ID (optional) ────────────────────────────────────────
# Required only if Google login is enabled in the backend.
# Must match the GOOGLE_CLIENT_ID set in backend/.env.
# Leave blank to hide the "Sign in with Google" button.

VITE_GOOGLE_CLIENT_ID=123456789012-abcdefghijklmnopqrstuvwxyz012345.apps.googleusercontent.com
